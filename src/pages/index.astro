---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Accueil">
  <section class="hero">
    <div class="hero-fire">🔥</div>
    <h1>Soirée Guitare<br/>Feu de Camp</h1>
    <p class="hero-subtitle">Viens chanter avec nous autour du feu !</p>
  </section>

  <section class="info-grid">
    <div class="card info-card">
      <div class="info-icon">📅</div>
      <h2>Date</h2>
      <p>Samedi 6 juin 2026</p>
      <p class="info-detail">À partir de 19h</p>
    </div>

    <div class="card info-card">
      <div class="info-icon">📍</div>
      <h2>Lieu</h2>
      <p>À définir</p>
      <p class="info-detail">Adresse à venir</p>
    </div>

    <div class="card info-card">
      <div class="info-icon">🎸</div>
      <h2>Programme</h2>
      <p>Guitares, chansons & bonne humeur</p>
      <p class="info-detail">Tous niveaux bienvenus</p>
    </div>
  </section>

  <section class="qr-section card">
    <h2>📱 Accède aux paroles</h2>
    <p>Scanne le QR code pour afficher les paroles sur ton téléphone et chanter avec nous !</p>
    <a href={`${base}chansons/`} class="btn btn-accent">Voir la set-list →</a>
  </section>

  <section class="how-it-works">
    <h2>Comment ça marche ?</h2>
    <div class="steps-list">
      <div class="step">
        <span class="step-num">1</span>
        <p><strong>Scanne le QR code</strong> affiché près du feu</p>
      </div>
      <div class="step">
        <span class="step-num">2</span>
        <p><strong>Ouvre la set-list</strong> pour voir les chansons</p>
      </div>
      <div class="step">
        <span class="step-num">3</span>
        <p><strong>Chante avec nous</strong> en suivant les paroles !</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    text-align: center;
    padding: 2.5rem 0 2rem;
  }

  .hero-fire {
    font-size: 4rem;
    margin-bottom: 0.5rem;
    animation: flicker 2s infinite alternate;
  }

  @keyframes flicker {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.85; transform: scale(1.05); }
  }

  .hero h1 {
    font-size: 2.2rem;
    line-height: 1.2;
  }

  .hero-subtitle {
    margin-top: 0.75rem;
    font-size: 1.15rem;
    color: var(--text-secondary);
  }

  /* Info Grid */
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }

  .info-card {
    text-align: center;
  }

  .info-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .info-card h2 {
    font-size: 1.1rem;
    color: var(--accent);
  }

  .info-detail {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
  }

  /* QR Section */
  .qr-section {
    text-align: center;
    margin: 2rem 0;
    padding: 2rem;
  }

  .qr-section h2 {
    color: var(--accent);
  }

  .qr-section p {
    margin: 0.75rem 0 1.25rem;
    color: var(--text-secondary);
  }

  /* How it works */
  .how-it-works {
    margin: 2rem 0;
  }

  .how-it-works h2 {
    text-align: center;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .steps-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .step {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
  }

  .step-num {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: var(--bg-primary);
    border-radius: 50%;
    font-weight: 700;
    font-size: 1.1rem;
  }

  .step p {
    color: var(--text-secondary);
  }

  .step strong {
    color: var(--text-primary);
  }
</style>
