---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const chansons = await getCollection('chansons');
  const sorted = chansons.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((chanson, index) => ({
    params: { slug: chanson.id },
    props: {
      chanson,
      prev: index > 0 ? sorted[index - 1] : null,
      next: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { chanson, prev, next } = Astro.props;
const base = import.meta.env.BASE_URL;
const rawBody = await Astro.slots.render('default');

// Read the raw markdown body (not rendered HTML)
const file = chanson.body ?? '';
---

<BaseLayout title={`${chanson.data.title} — ${chanson.data.artist}`}>
  <div class="song-page">
    <!-- Header -->
    <div class="song-header">
      <a href={`${base}chansons/`} class="back-link">← Set-list</a>
      <h1>{chanson.data.title}</h1>
      <p class="song-artist">{chanson.data.artist}</p>
    </div>

    <!-- Capo banner (always visible in musician mode) -->
    {chanson.data.capo > 0 && (
      <div class="capo-banner musician-only">
        ⚠️ Capo fret {chanson.data.capo}
      </div>
    )}

    <!-- Metadata (musician view) -->
    <div class="song-meta musician-only card">
      <div class="meta-item">
        <span class="meta-label">Tonalité</span>
        <span class="meta-value" id="current-key">{chanson.data.key}</span>
      </div>
      {chanson.data.bpm && (
        <div class="meta-item">
          <span class="meta-label">BPM</span>
          <span class="meta-value">{chanson.data.bpm}</span>
        </div>
      )}
      <div class="meta-item">
        <span class="meta-label">Mesure</span>
        <span class="meta-value">{chanson.data.timeSig}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Difficulté</span>
        <span class="meta-value">{chanson.data.difficulty}</span>
      </div>
      {chanson.data.pdf && (
        <a href={`${base}partitions/${chanson.data.pdf}`} class="btn pdf-link" target="_blank">📄 Partition PDF</a>
      )}
    </div>

    <!-- View toggle + Transpose -->
    <div class="controls">
      <div class="view-toggle">
        <button class="btn btn-accent" id="btn-public">Public</button>
        <button class="btn" id="btn-musician">Musicien</button>
      </div>
      <div class="transpose-controls musician-only">
        <button class="btn" id="transpose-down">−</button>
        <span id="transpose-value">0</span>
        <button class="btn" id="transpose-up">+</button>
      </div>
    </div>

    <!-- Chord diagrams (musician view, collapsible) -->
    <div class="chord-diagrams musician-only card" id="chord-diagrams">
      <button class="chord-diagrams-toggle" id="chord-toggle" type="button">
        <span class="meta-label">Accords utilisés</span>
        <span class="chord-toggle-icon" id="chord-toggle-icon">▸</span>
      </button>
      <div class="chord-diagrams-grid" id="chord-grid" hidden></div>
    </div>

    <!-- Chord zoom overlay -->
    <div class="chord-overlay" id="chord-overlay" hidden>
      <div class="chord-overlay-content" id="chord-overlay-content"></div>
    </div>

    <!-- Lyrics -->
    <div class="lyrics card" id="lyrics-container">
      <pre id="lyrics-raw" hidden>{file}</pre>
      <pre id="original-key" hidden>{chanson.data.key}</pre>
      <div id="lyrics-rendered"></div>
    </div>

    <!-- Auto-scroll -->
    <button class="autoscroll-fab" id="autoscroll-btn" title="Auto-scroll">
      <span id="autoscroll-icon">▶</span>
    </button>
    <div class="autoscroll-speed" id="autoscroll-speed" hidden>
      <button class="btn btn-speed" id="speed-down">−</button>
      <span id="speed-label">1x</span>
      <button class="btn btn-speed" id="speed-up">+</button>
    </div>

    <!-- Navigation -->
    <nav class="song-nav">
      {prev ? (
        <a href={`${base}chanson/${prev.id}/`} class="btn nav-prev">← {prev.data.title}</a>
      ) : <span />}
      {next ? (
        <a href={`${base}chanson/${next.id}/`} class="btn nav-next">{next.data.title} →</a>
      ) : <span />}
    </nav>
  </div>
</BaseLayout>

<style>
  .song-page {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .song-header {
    text-align: center;
  }

  .back-link {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .back-link:hover {
    color: var(--accent);
  }

  .song-header h1 {
    margin-top: 0.5rem;
    font-size: 1.8rem;
  }

  .song-artist {
    color: var(--text-secondary);
    font-size: 1.05rem;
  }

  /* Meta */
  .song-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    justify-content: center;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .meta-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
  }

  .meta-value {
    font-weight: 600;
    color: var(--accent);
  }

  .pdf-link {
    margin-left: auto;
  }

  /* Controls */
  .controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .view-toggle {
    display: flex;
    gap: 0.5rem;
  }

  .transpose-controls {
    align-items: center;
    gap: 0.5rem;
  }

  .transpose-controls span {
    min-width: 2rem;
    text-align: center;
    font-weight: 700;
    color: var(--accent);
    font-size: 1.1rem;
  }

  /* Lyrics */
  .lyrics {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    line-height: 1.9;
    white-space: pre-wrap;
    overflow-x: auto;
    padding-bottom: 4rem;
  }

  .lyrics :global(.chord-pair) {
    display: inline-block;
    vertical-align: bottom;
  }

  .lyrics :global(.chord) {
    display: block;
    color: var(--accent);
    font-weight: 700;
    font-size: 0.82em;
    line-height: 1.3;
    white-space: nowrap;
  }

  .lyrics :global(.line) {
    display: block;
    min-height: 1.5em;
  }

  .lyrics :global(.line.has-chords) {
    line-height: 1.4;
    margin-top: 0.3em;
  }

  .lyrics :global(.section-refrain) {
    border-left: 3px solid var(--accent);
    padding-left: 0.75rem;
    margin: 0.5rem 0;
  }

  .lyrics :global(.section-label) {
    display: block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    background: var(--accent-glow);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    margin: 1rem 0 0.3rem;
    width: fit-content;
  }

  /* Capo banner */
  .capo-banner {
    background: #b45309;
    color: #fff;
    text-align: center;
    font-weight: 700;
    font-size: 1.05rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    letter-spacing: 0.02em;
  }

  /* Chord diagrams */
  .chord-diagrams {
    flex-direction: column;
    gap: 0.5rem;
  }

  .chord-diagrams-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem 0;
    color: inherit;
  }

  .chord-toggle-icon {
    color: var(--accent);
    font-size: 0.85rem;
    transition: transform 0.2s;
  }

  .chord-toggle-icon.open {
    transform: rotate(90deg);
  }

  .chord-diagrams-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    padding-top: 0.5rem;
  }

  .chord-diagrams-grid[hidden] {
    display: none;
  }

  .chord-diagrams :global(.chord-diagram) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 6px;
    transition: background 0.15s;
  }

  .chord-diagrams :global(.chord-diagram:hover) {
    background: var(--accent-glow);
  }

  .chord-diagrams :global(.chord-diagram-name) {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  /* Chord zoom overlay */
  .chord-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .chord-overlay[hidden] {
    display: none;
  }

  .chord-overlay-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .chord-overlay-content :global(.chord-diagram-name) {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  /* Navigation */
  .song-nav {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .nav-prev, .nav-next {
    max-width: 45%;
    font-size: 0.85rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Musician-only elements hidden by default */
  .musician-only {
    display: none;
  }

  :global(body.view-musician) .musician-only {
    display: flex;
  }

  /* Auto-scroll FAB */
  .autoscroll-fab {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--accent);
    color: var(--bg);
    border: none;
    font-size: 1.2rem;
    cursor: pointer;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.4);
    transition: background 0.2s;
  }

  .autoscroll-fab:hover {
    background: var(--accent-hover, #f0a020);
  }

  .autoscroll-fab.active {
    background: #f87171;
  }

  .autoscroll-speed {
    position: fixed;
    bottom: 5rem;
    right: 1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.3rem 0.5rem;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }

  .btn-speed {
    width: 1.8rem;
    height: 1.8rem;
    padding: 0;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #speed-label {
    min-width: 1.8rem;
    text-align: center;
    font-weight: 700;
    color: var(--accent);
    font-size: 0.85rem;
  }
</style>

<script>
  // === Notes & Transposition ===
  const NOTES_SHARP = ['C', 'C#', 'D', 'D#', 'E', 'F', 'F#', 'G', 'G#', 'A', 'A#', 'B'];
  const NOTES_FLAT  = ['C', 'Db', 'D', 'Eb', 'E', 'F', 'Gb', 'G', 'Ab', 'A', 'Bb', 'B'];

  function noteIndex(note: string): number {
    const n = note.replace('b', 'b');
    let idx = NOTES_SHARP.indexOf(n);
    if (idx === -1) idx = NOTES_FLAT.indexOf(n);
    return idx;
  }

  function transposeChord(chord: string, semitones: number): string {
    // Handle compound chords like A7sus4, F#m, Bbmaj7
    const match = chord.match(/^([A-G][#b]?)(.*)/);
    if (!match) return chord;
    const [, root, suffix] = match;
    const idx = noteIndex(root);
    if (idx === -1) return chord;
    const newIdx = ((idx + semitones) % 12 + 12) % 12;
    // Use sharps if original had sharp, flats if had flat
    const useFlat = root.includes('b');
    const newRoot = useFlat ? NOTES_FLAT[newIdx] : NOTES_SHARP[newIdx];
    return newRoot + suffix;
  }

  // === Chord Diagram Database ===
  // Format: [frets] as string (x=mute, 0=open, 1-9=fret), barré fret (0=none)
  // Standard tuning: E A D G B E
  type ChordDef = { frets: string; baseFret: number; barres?: number[] };
  const CHORD_DB: Record<string, ChordDef> = {
    // Major
    'C':    { frets: 'x32010', baseFret: 1 },
    'D':    { frets: 'xx0232', baseFret: 1 },
    'E':    { frets: '022100', baseFret: 1 },
    'F':    { frets: '133211', baseFret: 1, barres: [1] },
    'G':    { frets: '320003', baseFret: 1 },
    'A':    { frets: 'x02220', baseFret: 1 },
    'B':    { frets: 'x24442', baseFret: 1, barres: [2] },
    'C#':   { frets: 'x46664', baseFret: 1, barres: [4] },
    'Db':   { frets: 'x46664', baseFret: 1, barres: [4] },
    'D#':   { frets: 'x68886', baseFret: 1, barres: [6] },
    'Eb':   { frets: 'x68886', baseFret: 1, barres: [6] },
    'F#':   { frets: '244322', baseFret: 1, barres: [2] },
    'Gb':   { frets: '244322', baseFret: 1, barres: [2] },
    'G#':   { frets: '466544', baseFret: 1, barres: [4] },
    'Ab':   { frets: '466544', baseFret: 1, barres: [4] },
    'A#':   { frets: 'x13331', baseFret: 1, barres: [1] },
    'Bb':   { frets: 'x13331', baseFret: 1, barres: [1] },
    // Minor
    'Am':   { frets: 'x02210', baseFret: 1 },
    'Bm':   { frets: 'x24432', baseFret: 1, barres: [2] },
    'Cm':   { frets: 'x35543', baseFret: 1, barres: [3] },
    'Dm':   { frets: 'xx0231', baseFret: 1 },
    'Em':   { frets: '022000', baseFret: 1 },
    'Fm':   { frets: '133111', baseFret: 1, barres: [1] },
    'Gm':   { frets: '355333', baseFret: 1, barres: [3] },
    'F#m':  { frets: '244222', baseFret: 1, barres: [2] },
    'Gbm':  { frets: '244222', baseFret: 1, barres: [2] },
    'G#m':  { frets: '466444', baseFret: 1, barres: [4] },
    'Abm':  { frets: '466444', baseFret: 1, barres: [4] },
    'A#m':  { frets: 'x13321', baseFret: 1, barres: [1] },
    'Bbm':  { frets: 'x13321', baseFret: 1, barres: [1] },
    'C#m':  { frets: 'x46654', baseFret: 1, barres: [4] },
    'Dbm':  { frets: 'x46654', baseFret: 1, barres: [4] },
    'D#m':  { frets: 'x68876', baseFret: 1, barres: [6] },
    'Ebm':  { frets: 'x68876', baseFret: 1, barres: [6] },
    // 7th
    'A7':   { frets: 'x02020', baseFret: 1 },
    'B7':   { frets: 'x21202', baseFret: 1 },
    'C7':   { frets: 'x32310', baseFret: 1 },
    'D7':   { frets: 'xx0212', baseFret: 1 },
    'E7':   { frets: '020100', baseFret: 1 },
    'F7':   { frets: '131211', baseFret: 1, barres: [1] },
    'G7':   { frets: '320001', baseFret: 1 },
    // sus4
    'Asus4':   { frets: 'x02230', baseFret: 1 },
    'Dsus4':   { frets: 'xx0233', baseFret: 1 },
    'Esus4':   { frets: '022200', baseFret: 1 },
    // 7sus4
    'A7sus4':  { frets: 'x02030', baseFret: 1 },
    'D7sus4':  { frets: 'xx0213', baseFret: 1 },
    // Minor 7
    'Am7':  { frets: 'x02010', baseFret: 1 },
    'Bm7':  { frets: 'x20202', baseFret: 1 },
    'Dm7':  { frets: 'xx0211', baseFret: 1 },
    'Em7':  { frets: '022030', baseFret: 1 },
    'Fm7':  { frets: '131111', baseFret: 1, barres: [1] },
    'Gm7':  { frets: '353333', baseFret: 1, barres: [3] },
    'F#m7': { frets: '242222', baseFret: 1, barres: [2] },
    'C#m7': { frets: 'x46454', baseFret: 1, barres: [4] },
  };

  // Normalize chord name for DB lookup: try full name, then simplify
  function lookupChord(name: string): ChordDef | null {
    if (CHORD_DB[name]) return CHORD_DB[name];
    // Try common equivalences: e.g., Am7sus4 → look for Am7, then Am
    const m = name.match(/^([A-G][#b]?)(m?)(.*)$/);
    if (!m) return null;
    const [, root, minor, ext] = m;
    // Try root+minor+ext, root+minor+simplified ext, root+minor
    const tryNames = [root + minor + ext, root + minor];
    for (const n of tryNames) {
      if (CHORD_DB[n]) return CHORD_DB[n];
    }
    return null;
  }

  // Extract unique chords from raw song text
  function extractChords(raw: string, semitones: number): string[] {
    const chordRegex = /\[([^\]]+)\]/g;
    const seen = new Set<string>();
    const ordered: string[] = [];
    let m;
    while ((m = chordRegex.exec(raw)) !== null) {
      const transposed = transposeChord(m[1], semitones);
      if (!seen.has(transposed)) {
        seen.add(transposed);
        ordered.push(transposed);
      }
    }
    return ordered;
  }

  // SVG chord diagram renderer
  function renderChordSVG(name: string, def: ChordDef, scale: number = 1): string {
    const W = 64 * scale, H = 80 * scale;
    const pad = { top: 6 * scale, left: 14 * scale, right: 6 * scale, bottom: 3 * scale };
    const strings = 6;
    const frets = 4;
    const sw = (W - pad.left - pad.right) / (strings - 1);
    const fh = (H - pad.top - pad.bottom) / frets;
    const x = (s: number) => pad.left + s * sw;
    const y = (f: number) => pad.top + f * fh;

    let svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${W} ${H}" width="${W}" height="${H}">`;

    // Nut (thick bar at top if baseFret=1)
    if (def.baseFret === 1) {
      svg += `<rect x="${pad.left - 1 * scale}" y="${pad.top - 2 * scale}" width="${(strings - 1) * sw + 2 * scale}" height="${3 * scale}" fill="#f5e6d0" rx="${1 * scale}"/>`;
    }

    // Fret lines
    for (let f = 0; f <= frets; f++) {
      svg += `<line x1="${x(0)}" y1="${y(f)}" x2="${x(strings - 1)}" y2="${y(f)}" stroke="#6b5a42" stroke-width="${0.8 * scale}"/>`;
    }
    // String lines
    for (let s = 0; s < strings; s++) {
      svg += `<line x1="${x(s)}" y1="${y(0)}" x2="${x(s)}" y2="${y(frets)}" stroke="#6b5a42" stroke-width="${0.6 * scale}"/>`;
    }

    // Barré
    if (def.barres) {
      for (const bFret of def.barres) {
        const relFret = bFret - def.baseFret + 1;
        if (relFret >= 1 && relFret <= frets) {
          // Find first and last string pressed at this fret
          let first = -1, last = -1;
          for (let s = 0; s < 6; s++) {
            const f = def.frets[s];
            if (f !== 'x' && parseInt(f) === bFret) {
              if (first === -1) first = s;
              last = s;
            }
          }
          if (first !== -1 && last !== first) {
            const cy = y(relFret) - fh / 2;
            svg += `<rect x="${x(first) - 3 * scale}" y="${cy - 4 * scale}" width="${(last - first) * sw + 6 * scale}" height="${8 * scale}" rx="${4 * scale}" fill="#e8943a"/>`;
          }
        }
      }
    }

    // Dots
    for (let s = 0; s < strings; s++) {
      const ch = def.frets[s];
      if (ch === 'x') {
        svg += `<text x="${x(s)}" y="${pad.top - 5 * scale}" text-anchor="middle" fill="#c4a882" font-size="${9 * scale}" font-family="sans-serif">×</text>`;
      } else if (ch === '0') {
        svg += `<circle cx="${x(s)}" cy="${pad.top - 6 * scale}" r="${3 * scale}" fill="none" stroke="#c4a882" stroke-width="${1 * scale}"/>`;
      } else {
        const fretNum = parseInt(ch);
        const relFret = fretNum - def.baseFret + 1;
        if (relFret >= 1 && relFret <= frets) {
          const cy = y(relFret) - fh / 2;
          // Skip dot if part of barré (except first occurrence)
          const isBarré = def.barres?.includes(fretNum);
          if (!isBarré) {
            svg += `<circle cx="${x(s)}" cy="${cy}" r="${4 * scale}" fill="#e8943a"/>`;
          }
        }
      }
    }

    // Base fret indicator
    if (def.baseFret > 1) {
      svg += `<text x="${pad.left - 7 * scale}" y="${y(0) + fh / 2 + 3 * scale}" text-anchor="middle" fill="#c4a882" font-size="${8 * scale}" font-family="sans-serif">${def.baseFret}</text>`;
    }

    svg += '</svg>';
    return svg;
  }

  function renderChordDiagrams(semitones: number) {
    const grid = document.getElementById('chord-grid')!;
    const chords = extractChords(raw, semitones);
    let html = '';
    for (const chord of chords) {
      const def = lookupChord(chord);
      if (def) {
        html += `<div class="chord-diagram"><span class="chord-diagram-name">${escapeHtml(chord)}</span>${renderChordSVG(chord, def)}</div>`;
      } else {
        html += `<div class="chord-diagram"><span class="chord-diagram-name">${escapeHtml(chord)}</span><span style="font-size:0.65rem;color:var(--text-secondary);">?</span></div>`;
      }
    }
    grid.innerHTML = html;
  }

  // === ChordPro Parser ===
  function parseAndRender(raw: string, semitones: number, showChords: boolean): string {
    const lines = raw.split('\n');
    let html = '';

    for (const line of lines) {
      // Section markers: {section Intro}, {section Couplet 1}, etc.
      const sectionMatch = line.trim().match(/^\{section\s+(.+)\}$/);
      if (sectionMatch) {
        html += `<span class="section-label">${escapeHtml(sectionMatch[1])}</span>`;
        continue;
      }
      if (line.trim() === '{refrain}') {
        html += '<span class="section-label">Refrain</span><div class="section-refrain">';
        continue;
      }
      if (line.trim() === '{/refrain}') {
        html += '</div>';
        continue;
      }
      if (line.trim() === '') {
        html += '<span class="line">&nbsp;</span>';
        continue;
      }

      const regex = /\[([^\]]+)\]/g;
      let lastIndex = 0;
      let m;
      let lineHtml = '';

      if (showChords) {
        // Build chord-pair segments: chord displayed above its lyrics
        const segments: { chord: string | null; text: string }[] = [];
        while ((m = regex.exec(line)) !== null) {
          const textBefore = line.slice(lastIndex, m.index);
          if (segments.length === 0 && textBefore) {
            segments.push({ chord: null, text: textBefore });
          } else if (segments.length > 0) {
            segments[segments.length - 1].text += textBefore;
          }
          segments.push({ chord: transposeChord(m[1], semitones), text: '' });
          lastIndex = regex.lastIndex;
        }
        const remainder = line.slice(lastIndex);
        if (segments.length > 0) {
          segments[segments.length - 1].text += remainder;
        }

        if (segments.length > 0) {
          for (const seg of segments) {
            const chordHtml = seg.chord
              ? `<span class="chord">${escapeHtml(seg.chord)}</span>`
              : '<span class="chord">&nbsp;</span>';
            const textHtml = escapeHtml(seg.text) || '&nbsp;';
            lineHtml += `<span class="chord-pair">${chordHtml}${textHtml}</span>`;
          }
          html += `<span class="line has-chords">${lineHtml}</span>`;
        } else {
          html += `<span class="line">${escapeHtml(line)}</span>`;
        }
      } else {
        // Public view: lyrics only, strip chords
        while ((m = regex.exec(line)) !== null) {
          lineHtml += escapeHtml(line.slice(lastIndex, m.index));
          lastIndex = regex.lastIndex;
        }
        lineHtml += escapeHtml(line.slice(lastIndex));
        // Skip lines that become empty after stripping chords (e.g. instrumental lines)
        if (lineHtml.trim()) {
          html += `<span class="line">${lineHtml}</span>`;
        }
      }
    }
    return html;
  }

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  // === DOM Setup ===
  const raw = document.getElementById('lyrics-raw')!.textContent || '';
  const originalKey = document.getElementById('original-key')!.textContent || '';
  const rendered = document.getElementById('lyrics-rendered')!;
  const btnPublic = document.getElementById('btn-public')!;
  const btnMusician = document.getElementById('btn-musician')!;
  const transposeUp = document.getElementById('transpose-up')!;
  const transposeDown = document.getElementById('transpose-down')!;
  const transposeValue = document.getElementById('transpose-value')!;
  const currentKeyEl = document.getElementById('current-key')!;

  let semitones = 0;

  function isMusician(): boolean {
    return document.body.classList.contains('view-musician');
  }

  function render() {
    rendered.innerHTML = parseAndRender(raw, semitones, isMusician());
    transposeValue.textContent = (semitones >= 0 ? '+' : '') + semitones;
    // Update displayed key with transposition
    currentKeyEl.textContent = transposeChord(originalKey, semitones);
    // Update chord diagrams
    renderChordDiagrams(semitones);
  }

  function setView(view: string) {
    if (view === 'musician') {
      document.body.classList.add('view-musician');
      btnMusician.classList.add('btn-accent');
      btnPublic.classList.remove('btn-accent');
    } else {
      document.body.classList.remove('view-musician');
      btnPublic.classList.add('btn-accent');
      btnMusician.classList.remove('btn-accent');
    }
    localStorage.setItem('view', view);
    render();
  }

  btnPublic.addEventListener('click', () => setView('public'));
  btnMusician.addEventListener('click', () => setView('musician'));

  transposeUp.addEventListener('click', () => {
    semitones = (semitones + 1) % 12;
    render();
  });

  transposeDown.addEventListener('click', () => {
    semitones = ((semitones - 1) % 12 + 12) % 12;
    render();
  });

  // Init
  const saved = localStorage.getItem('view');
  if (saved) setView(saved); else render();

  // === Chord diagrams toggle ===
  const chordToggle = document.getElementById('chord-toggle')!;
  const chordGrid = document.getElementById('chord-grid')!;
  const chordToggleIcon = document.getElementById('chord-toggle-icon')!;

  chordToggle.addEventListener('click', () => {
    const isOpen = !chordGrid.hidden;
    chordGrid.hidden = isOpen;
    chordToggleIcon.classList.toggle('open', !isOpen);
    localStorage.setItem('chordsOpen', isOpen ? '' : '1');
  });

  // Restore chord panel state
  if (localStorage.getItem('chordsOpen') === '1') {
    chordGrid.hidden = false;
    chordToggleIcon.classList.add('open');
  }

  // === Chord zoom on click ===
  const chordOverlay = document.getElementById('chord-overlay')!;
  const chordOverlayContent = document.getElementById('chord-overlay-content')!;

  chordGrid.addEventListener('click', (e) => {
    const diagram = (e.target as HTMLElement).closest('.chord-diagram');
    if (!diagram) return;
    const name = diagram.querySelector('.chord-diagram-name')?.textContent || '';
    const def = lookupChord(name);
    if (!def) return;
    chordOverlayContent.innerHTML =
      `<span class="chord-diagram-name">${escapeHtml(name)}</span>${renderChordSVG(name, def, 3.5)}`;
    chordOverlay.hidden = false;
  });

  chordOverlay.addEventListener('click', () => {
    chordOverlay.hidden = true;
  });

  // === Auto-scroll ===
  const scrollBtn = document.getElementById('autoscroll-btn')!;
  const scrollIcon = document.getElementById('autoscroll-icon')!;
  const speedPanel = document.getElementById('autoscroll-speed')!;
  const speedLabel = document.getElementById('speed-label')!;
  const speedUp = document.getElementById('speed-up')!;
  const speedDown = document.getElementById('speed-down')!;

  const SPEEDS = [0.5, 1, 1.5, 2, 3];
  let speedIndex = 1;
  let scrolling = false;
  let scrollRAF: number | null = null;
  let lastScrollTime: number | null = null;
  let targetScrollY = 0;

  const BASE_PX_PER_SEC = 48;

  function updateSpeedLabel() {
    speedLabel.textContent = SPEEDS[speedIndex] + 'x';
  }

  function stopScrolling() {
    scrolling = false;
    document.documentElement.classList.remove('autoscrolling');
    scrollBtn.classList.remove('active');
    scrollIcon.textContent = '▶';
    speedPanel.hidden = true;
    if (scrollRAF) cancelAnimationFrame(scrollRAF);
  }

  function autoScroll(timestamp: number) {
    if (!scrolling) return;

    if (lastScrollTime !== null) {
      const elapsed = timestamp - lastScrollTime;
      targetScrollY += SPEEDS[speedIndex] * BASE_PX_PER_SEC * elapsed / 1000;

      // Stop at bottom of page
      const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
      if (targetScrollY >= maxScroll) {
        targetScrollY = maxScroll;
        window.scrollTo(0, targetScrollY);
        stopScrolling();
        return;
      }

      window.scrollTo(0, Math.round(targetScrollY));
    }

    lastScrollTime = timestamp;
    scrollRAF = requestAnimationFrame(autoScroll);
  }

  scrollBtn.addEventListener('click', () => {
    if (scrolling) {
      stopScrolling();
    } else {
      scrolling = true;
      document.documentElement.classList.add('autoscrolling');
      scrollBtn.classList.add('active');
      scrollIcon.textContent = '⏸';
      speedPanel.hidden = false;
      lastScrollTime = null;
      targetScrollY = window.scrollY;
      scrollRAF = requestAnimationFrame(autoScroll);
    }
  });

  // Stop auto-scroll when user touches the screen (mobile)
  document.addEventListener('touchstart', (e) => {
    if (!scrolling) return;
    const target = e.target as HTMLElement;
    if (target.closest('#autoscroll-btn, #autoscroll-speed')) return;
    stopScrolling();
  }, { passive: true });

  speedUp.addEventListener('click', () => {
    if (speedIndex < SPEEDS.length - 1) speedIndex++;
    updateSpeedLabel();
  });

  speedDown.addEventListener('click', () => {
    if (speedIndex > 0) speedIndex--;
    updateSpeedLabel();
  });

  // === Wake Lock (keep screen on) ===
  let wakeLock: WakeLockSentinel | null = null;

  async function requestWakeLock() {
    if ('wakeLock' in navigator) {
      try {
        wakeLock = await navigator.wakeLock.request('screen');
        wakeLock.addEventListener('release', () => { wakeLock = null; });
      } catch (_) { /* silently fail on unsupported/denied */ }
    }
  }

  function releaseWakeLock() {
    wakeLock?.release();
    wakeLock = null;
  }

  // Request wake lock on page load, re-acquire on visibility change
  requestWakeLock();
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') requestWakeLock();
  });
</script>
